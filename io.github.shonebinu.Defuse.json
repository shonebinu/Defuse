      "name": "onnx-models",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p ${FLATPAK_DEST}/share/io.github.shonebinu.Defuse/models",
        "mv isnet-general-use.onnx ${FLATPAK_DEST}/share/io.github.shonebinu.Defuse/models/isnet-general-use.onnx"
      ],
      "sources": [
        {
          "type": "file",
