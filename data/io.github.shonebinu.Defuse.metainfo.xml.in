<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.shonebinu.Defuse</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Defuse</name>
  <summary>Remove image backgrounds locally</summary>
  <description>
    <p>Defuse let's you remove background from photos locally.</p>
    <p>Features:</p>
    <ul>
      <li>Images are processed locally</li>
      <li>Uses WebGPU acceleration on x86_64 systems</li>
    </ul>
  </description>

  <developer id="io.github.shonebinu">
    <name>Shone Binu</name>
  </developer>

  <!-- Required: Should be a link to the upstream homepage for the component -->
  <url type="homepage">https://github.com/shonebinu/Defuse</url>
  <!-- Recommended: It is highly recommended for open-source projects to display the source code
  repository -->
  <url type="vcs-browser">https://github.com/shonebinu/Defuse</url>
  <!-- Should point to the software's bug tracking system, for users to report new bugs -->
  <url type="bugtracker">https://github.com/shonebinu/Defuse/issues</url>
  <!-- Should link a FAQ page for this software, to answer some of the most-asked questions in
  detail -->
  <!-- URLs of this type should point to a webpage where users can submit or modify translations of
  the upstream project -->
  <url type="translate">https://github.com/shonebinu/Defuse/tree/main/po</url>
  <!-- <url type="faq">https://example.org/faq</url> -->
  <!-- Should provide a web link to an online user's reference, a software manual or help page -->
  <url type="help">https://github.com/shonebinu/Defuse/issues</url>
  <!-- URLs of this type should point to a webpage showing information on how to donate to the
  described software project -->
  <url type="donation">https://ko-fi.com/shonebinu</url>
  <!-- This could for example be an HTTPS URL to an online form or a page describing how to contact
  the developer -->
  <url type="contact">https://shonebinu.com</url>
  <!-- URLs of this type should point to a webpage showing information on how to contribute to the
  described software project -->
  <url type="contribute">https://github.com/shonebinu/Defuse</url>

  <translation type="gettext">defuse</translation>
  <!-- All graphical applications having a desktop file must have this tag in the MetaInfo.
     If this is present, appstreamcli compose will pull icons, keywords and categories from the desktop
  file. -->
  <launchable type="desktop-id">io.github.shonebinu.Defuse.desktop</launchable>
  <!-- Use the OARS website (https://hughsie.github.io/oars/generate.html) to generate these and
  make sure to use oars-1.1 -->
  <content_rating type="oars-1.1" />

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <!-- Applications should set a brand color in both light and dark variants like so -->
  <branding>
    <color type="primary" scheme_preference="light">#ecba7c</color>
    <color type="primary" scheme_preference="dark">#67472d</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>
        https://raw.githubusercontent.com/shonebinu/Defuse/refs/heads/main/data/screenshots/initial.png</image>
      <caption>Initial Screen</caption>
    </screenshot>
    <screenshot>
      <image>
        https://raw.githubusercontent.com/shonebinu/Defuse/refs/heads/main/data/screenshots/img-remove.png</image>
      <caption>Image to be processed</caption>
    </screenshot>
    <screenshot>
      <image>
        https://raw.githubusercontent.com/shonebinu/Defuse/refs/heads/main/data/screenshots/img-save.png</image>
      <caption>Image after background removal</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="0.1.1" date="2026-05-04">
      <description translate="no">
        <p>Release v0.1.1</p>
        <ul>
          <li>Add fallback to cpu if webgpu fails</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-05-02">
      <!-- <url type="details">https://example.org/changelog.html#version_1.0.1</url> -->
      <description translate="no">
        <p>Release v0.1.0</p>
        <ul>
          <li>Initial release of the app</li>
        </ul>
      </description>
    </release>
  </releases>

</component>